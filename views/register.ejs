<%- include("partials/main_header.ejs") %>
<div class="register">
	<p class="register_title">Create account to start taking notes</p>
	<% if(locals.err){ %><p class="auth_error"><%= err %></p><% } %>
	<form action="/register" method="post">
		<input type="email" placeholder="Enter your email" name="email" required>
		<input type="password" placeholder="Create password" name="password" required minlength="8">
		<input type="password" placeholder="Confirm password" name="confirm_password" required minlength="8">
		<input type="submit" value="Register">
	</form>
	<p class="register_login_text">Already have an account? <a href="/login">Login now</a></p>
</div>
<%- include("partials/footer.ejs") %>
